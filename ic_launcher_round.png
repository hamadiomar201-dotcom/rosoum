    const fallbackUrl = generateStyledPlaceholderSvgData(prompt, category);
    return res.json({
      success: true,
      imageUrl: fallbackUrl,
      isPlaceholderFallback: true,
      message: "Generated custom styled graphic vector symbol (AI key missing)"
