    if (response?.generatedImages?.[0]?.image?.imageBytes) {
      const base64Bytes = response.generatedImages[0].image.imageBytes;
      const imageUrl = `data:image/jpeg;base64,${base64Bytes}`;
      return res.json({
        success: true,
        imageUrl,
        isPlaceholderFallback: false
